{
  // Formatter
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,

  // Collapse generated/config files under their parent in the explorer
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "package.json": "bun.lock, bunfig.toml, tsconfig.json, rsbuild.config.ts, .oxlintrc.json, .oxfmtrc.json",
    "router.tsx": "routeTree.gen.ts"
  },

  // Use the project's TypeScript for consistent typed-route inference
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,

  // Cleaner auto-imports across the typed router (uses the @/* alias in tsconfig)
  "js/ts.preferences.importModuleSpecifier": "shortest",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",

  // Treat generated/lock files as read-only and keep them out of search & file-watching
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true,
    "bun.lock": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true,
    "bun.lock": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true,
    "bun.lock": true
  }
}
