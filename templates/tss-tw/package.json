{
  "name": "tss-tw",
  "description": "A blank minimal TanStack Start application configured with Tailwind CSS",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev",
    "build": "tsc --noEmit && bun --bun vite build",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}
