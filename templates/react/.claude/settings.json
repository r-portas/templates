{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs $CLAUDE_PROJECT_DIR/node_modules/.bin/oxfmt",
            "statusMessage": "Formatting..."
          }
        ]
      }
    ]
  }
}
